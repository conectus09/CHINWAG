# ─── Next.js app ───────────────────────────────────────────────
# Public URL of the Socket.io server (browser connects here)
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# ─── Socket.io server (server/index.ts) ────────────────────────
SOCKET_PORT=3001
# Comma-separated allowed origins (your Next.js app URL)
CLIENT_ORIGIN=http://localhost:3000

# ─── Redis (strongly recommended on Render for real-user matching) ─
# Without Redis, ghost users can block the queue after restarts.
# Free option: https://upstash.com → Redis → copy the rediss:// URL
REDIS_URL=redis://localhost:6379

# Admin dashboard key (optional)
# ADMIN_KEY=chinwag-admin